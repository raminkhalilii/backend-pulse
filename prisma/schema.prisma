// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum AlertEventType {
  DOWN
  RECOVERY
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum MonitorFrequency {
  ONE_MIN    @map("1m")
  FIVE_MIN   @map("5m")
  THIRTY_MIN @map("30m")
}

enum PingStatus {
  UP
  DOWN
}

enum OAuthProvider {
  GOOGLE
  GITHUB
}

enum AlertChannelType {
  EMAIL
  WEBHOOK
  SLACK
  DISCORD
}

enum PlatformType {
  WEBHOOK
  SLACK
  DISCORD
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  name         String
  password     String? // Nullable: OAuth users have no password
  refreshToken String? // Stores the currently valid refresh token for JWT

  monitors       Monitor[]
  oauthAccounts  OAuthAccount[]
  alertChannels  AlertChannel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OAuthAccount {
  id                String        @id @default(uuid())
  userId            String
  provider          OAuthProvider
  providerAccountId String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Monitor {
  id        String           @id @default(uuid())
  userId    String
  name      String
  url       String
  frequency MonitorFrequency @default(ONE_MIN)
  isActive  Boolean          @default(true) // Ability to pause a monitor

  consecutiveFailures Int        @default(0)
  alertThreshold      Int        @default(2)
  lastAlertedAt       DateTime?
  lastStatus          PingStatus?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  heartbeats        Heartbeat[]
  summaries         HourlySummary[]
  alertEvents       AlertEvent[]
  alertSettings     MonitorAlertSettings?
  alertChannelLinks MonitorAlertChannel[]
  suppressedAlerts  SuppressedAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Heartbeat {
  id        BigInt     @id @default(autoincrement())
  monitorId String
  status    PingStatus
  latencyMs Int? // Nullable in case of a complete timeout where TTFB isn't reached

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  timestamp DateTime @default(now())

  // Indexing by monitorId and timestamp is crucial for dashboard queries
  @@index([monitorId, timestamp(sort: Desc)])
}

model HourlySummary {
  id            String   @id @default(uuid())
  monitorId     String
  hour          DateTime // Truncated to the exact hour (e.g., 2026-02-20T14:00:00Z)
  uptimePercent Float
  avgLatencyMs  Float

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([monitorId, hour]) // A monitor can only have one summary per specific hour
}

model AlertEvent {
  id             String         @id @default(uuid())
  monitorId      String
  type           AlertEventType
  triggeredAt    DateTime       @default(now())
  deliveryStatus DeliveryStatus @default(PENDING)
  metadata       Json?

  monitor             Monitor              @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  webhookDeliveryLogs WebhookDeliveryLog[]

  @@index([monitorId, triggeredAt(sort: Desc)])
}

model AlertChannel {
  id      String           @id @default(uuid())
  userId  String
  type    AlertChannelType
  value   String           // Email address, webhook URL, etc.
  label   String?          // Optional friendly name e.g. "Work email"
  enabled Boolean          @default(true)
  secret           String?          // Optional HMAC-SHA256 signing secret (WEBHOOK channels only)
  platformMetadata Json?            // Optional display config: { workspaceName?, channelName? } for SLACK; { serverName?, channelName? } for DISCORD

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  webhookDeliveryLogs WebhookDeliveryLog[]
  monitorLinks        MonitorAlertChannel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ── Phase 5: Per-monitor alert settings ───────────────────────────────────────

/// Per-monitor alert configuration. Created lazily on first access; if absent,
/// the engine falls back to Monitor.alertThreshold and safe defaults.
model MonitorAlertSettings {
  id                  String  @id @default(uuid())
  monitorId           String  @unique
  /// Override the monitor-level threshold for DOWN alerts.
  alertThreshold      Int     @default(2)
  /// After this many consecutive failures an escalation alert fires (must be > alertThreshold).
  escalationThreshold Int     @default(5)
  /// Send a RECOVERY alert when the monitor comes back UP.
  alertOnRecovery     Boolean @default(true)
  quietHoursEnabled   Boolean @default(false)
  /// UTC time string "HH:MM". Required when quietHoursEnabled is true.
  quietHoursStart     String?
  /// UTC time string "HH:MM". Required when quietHoursEnabled is true.
  quietHoursEnd       String?
  /// JSON array of day-of-week numbers [0–6] where 0 = Sunday. Defaults to all 7 days.
  quietHoursDays      Json    @default("[0,1,2,3,4,5,6]")

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Junction table: links a monitor to its chosen alert channels.
/// isEscalation=true channels only fire once consecutiveFailures >= escalationThreshold.
model MonitorAlertChannel {
  id             String  @id @default(uuid())
  monitorId      String
  alertChannelId String
  isEscalation   Boolean @default(false)

  monitor      Monitor      @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  alertChannel AlertChannel @relation(fields: [alertChannelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([monitorId, alertChannelId])
  @@index([monitorId])
}

/// Audit log for alerts suppressed by the quiet-hours gate.
model SuppressedAlert {
  id            String         @id @default(uuid())
  monitorId     String
  type          AlertEventType
  suppressedAt  DateTime       @default(now())
  reason        String         // e.g. "quiet_hours"
  quietHoursEnd String?        // "HH:MM" — when alerts resume

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, suppressedAt(sort: Desc)])
}

model WebhookDeliveryLog {
  id             String   @id @default(uuid())
  alertChannelId String
  alertEventId   String
  url            String   // Snapshot of URL at time of delivery
  statusCode     Int?     // HTTP response code received (null if network/timeout error)
  responseTimeMs Int
  success        Boolean
  errorMessage   String?
  platformType   PlatformType @default(WEBHOOK) // Distinguishes WEBHOOK vs SLACK vs DISCORD log entries
  attemptedAt    DateTime     @default(now())

  alertChannel AlertChannel @relation(fields: [alertChannelId], references: [id], onDelete: Cascade)
  alertEvent   AlertEvent   @relation(fields: [alertEventId], references: [id], onDelete: Cascade)

  @@index([alertChannelId, attemptedAt(sort: Desc)])
}
