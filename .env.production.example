# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=pulse_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=pulse_database
# Constructed automatically in docker-compose.prod.yml — do not set manually.
# DATABASE_URL=postgresql://...

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── JWT Secrets — generate with: openssl rand -hex 64 ────────────────────────
ACCESS_TOKEN_SECRET=
JWT_REFRESH_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
DOMAIN=pulsee.website

# ── Docker image tag (set by CI to the git SHA) ───────────────────────────────
GITHUB_REPOSITORY=raminkhalilii/pulse
IMAGE_TAG=latest
